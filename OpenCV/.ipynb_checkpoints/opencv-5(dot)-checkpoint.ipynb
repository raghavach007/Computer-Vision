    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "img = np.zeros((200, 200, 3), dtype=np.uint8)\n",
    "cv2.circle(img, (100, 100), 5, (255, 255, 255), -1)\n",
    "\n",
    "plt.imshow(img)\n",
    "plt.axis('off')\n",
    "plt.show()"

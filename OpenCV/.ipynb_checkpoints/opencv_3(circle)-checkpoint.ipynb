    "import cv2\n",
    "import numpy as np\n",
    "from matplotlib import pyplot as plt\n",
    "\n",
    "img = np.zeros((150, 150, 3), dtype=np.uint8)\n",
    "\n",
    "cv2.circle(img, (75, 75), 35, (255, 0, 0), 3)\n",
    "print( img.shape)\n",
    "\n",
    "plt.imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))\n",
    "plt.axis('off')\n",
    "plt.show()"
   ]
